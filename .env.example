# ============================================================
# ENVIRONMENT VARIABLES UNTUK PRODUCTION (VERCEL)
# ============================================================
# Copy values ini ke Vercel Dashboard > Settings > Environment Variables

# Database - Supabase PostgreSQL (session pooler, IPv4, Vercel-compatible)
# Ambil dari: Supabase Dashboard > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# JWT Secret untuk session admin (generate: openssl rand -base64 32)
JWT_SECRET=ubah-dengan-string-acak-yang-panjang-dan-aman

# Supabase - untuk Realtime (ambil dari Supabase Dashboard > Settings > API)
# Project URL:
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Anon public key (safe to expose, bukan service role key!):
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5...anon-key-anda...

# ============================================================
# CATATAN:
# - [PROJECT-REF] = project ref Supabase Anda (mis. lorfloiepzqatelbiflk)
# - [PASSWORD] = password database Supabase Anda
# - [REGION] = region pooler (mis. eu-west-1)
# - Gunakan port 5432 (session pooler) — IPv4 & cocok untuk serverless Vercel
# - NEXT_PUBLIC_ prefix = variabel di-expose ke browser (diperlukan untuk Realtime)
# - Jangan commit file .env asli ke git! Hanya .env.example ini yang aman.
# ============================================================
