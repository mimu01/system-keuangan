# Database (SQLite untuk development lokal)
DATABASE_URL=file:./db/custom.db

# JWT Secret untuk session admin (generate string acak 32+ karakter)
# Contoh: openssl rand -base64 32
JWT_SECRET=ubah-dengan-string-acak-yang-panjang-dan-aman

# URL Realtime Service (socket.io) - default localhost:3003
# Di production, set ke URL service realtime Anda
REALTIME_SERVICE_URL=http://localhost:3003
